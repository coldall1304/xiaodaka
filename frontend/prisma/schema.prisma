// Prisma Schema for 小打卡 (优化版)
// 优化重点：索引优化、查询性能、数据一致性

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// 用户表
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系
  plans        Plan[]
  checkIns     CheckIn[]
  points       PointHistory[]

  @@map("users")
}

// 学习计划表
model Plan {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String   @default("study") // study, exercise, habit, other
  color       String   @default("#3B82F6")
  startDate   DateTime
  endDate     DateTime?
  frequency   String   @default("daily") // daily, weekly, biweekly, monthly, custom
  customDays  Json?    // JSON array [0,1,2,3,4,5,6] for custom frequency
  reminderTime String? // HH:mm format
  isActive    Boolean  @default(true)
  targetDays  Int?     // 目标天数（用于计算完成度）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关系
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns  CheckIn[]

  // 索引优化：按用户查询活跃计划
  @@index([userId, isActive])
  @@index([userId, startDate])
  @@map("plans")
}

// 打卡记录表
model CheckIn {
  id           String   @id @default(cuid())
  planId       String
  userId       String
  date         DateTime @db.Date // 仅存储日期，不存储时间
  completedAt  DateTime?
  note         String?
  duration     Int?     // 打卡时长（分钟）
  mood         String?  // 心情：great/good/okay/bad
  createdAt    DateTime @default(now())

  // 关系
  plan  Plan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 唯一约束：同一计划同一天只能打卡一次
  @@unique([planId, date])

  // 索引优化：按用户和时间范围查询
  @@index([userId, date])
  @@index([planId, date])
  @@map("check_ins")
}

// 积分历史表
model PointHistory {
  id        String   @id @default(cuid())
  userId    String
  points    Int      // 正数表示加分，负数表示扣分
  reason    String   // 获得原因（如：完成打卡、连续打卡奖励等）
  relatedId String?  // 关联记录 ID（如打卡记录 ID）
  createdAt DateTime @default(now())

  // 关系
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 索引优化：按用户和时间查询积分历史
  @@index([userId, createdAt])
  @@map("point_history")
}

// 连续打卡统计表（可选，用于快速计算连续打卡天数）
model Streak {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  streak    Int      @default(0) // 当前连续打卡天数
  best      Int      @default(0) // 最佳连续打卡天数
  lastDate  DateTime @default(now()) // 最后一次打卡日期
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, planId])
  @@index([userId])
  @@map("streaks")
}

// 用户设置表（可选）
model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  timezone            String   @default("Asia/Shanghai")
  dailyReminderTime   String?  // 默认提醒时间 HH:mm
  enableNotifications Boolean  @default(true)
  language            String   @default("zh-CN")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_settings")
}