generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  password     String
  name         String
  avatar       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  checkIns     CheckIn[]
  plans        Plan[]
  points       PointHistory[]
  membership   Membership?
  wishes       WishList[]
  achievements Achievement[]

  @@map("users")
}

model Plan {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  category     String    @default("study")
  color        String    @default("#3B82F6")
  startDate    DateTime
  endDate      DateTime?
  frequency    String    @default("daily")
  customDays   Json?
  reminderTime String?
  startTime    String?
  endTime      String?
  duration     Int?      // 时长模式（分钟）
  customPoints Int?      // 自定义积分
  attachments  Json?
  isActive     Boolean   @default(true)
  targetDays   Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  checkIns     CheckIn[]
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, startDate])
  @@map("plans")
}

model CheckIn {
  id          String    @id @default(cuid())
  planId      String
  userId      String
  date        DateTime  @db.Date
  completedAt DateTime?
  note        String?
  duration    Int?
  mood        String?
  createdAt   DateTime  @default(now())
  plan        Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([planId, date])
  @@index([userId, date])
  @@index([planId, date])
  @@map("check_ins")
}

model PointHistory {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  reason    String
  relatedId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("point_history")
}

model Membership {
  id           String   @id @default(cuid())
  userId       String   @unique
  type         String   @default("free") // free, monthly, yearly, lifetime
  startDate    DateTime @default(now())
  endDate      DateTime?
  isActive     Boolean  @default(true)
  autoRenew    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive, endDate])
  @@map("memberships")
}

model Streak {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  streak    Int      @default(0)
  best      Int      @default(0)
  lastDate  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, planId])
  @@index([userId])
  @@map("streaks")
}

model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  timezone            String   @default("Asia/Shanghai")
  dailyReminderTime   String?
  enableNotifications Boolean  @default(true)
  language            String   @default("zh-CN")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_settings")
}

model MembershipCode {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   // monthly, yearly, lifetime
  durationDays Int
  isUsed      Boolean  @default(false)
  usedBy      String?
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([code, isUsed])
  @@map("membership_codes")
}

// 愿望清单
model WishList {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  points      Int      // 所需积分
  icon        String   @default("🎁")
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  completedAt DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isCompleted])
  @@map("wish_list")
}

// 成就系统
model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String   // achievement type: first_checkin, streak_7, streak_30, etc.
  title       String
  description String
  icon        String
  points      Int
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("achievements")
}